<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- 相机预览 -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvOcrResult" />

    <!-- 拍照后的预览 -->
    <ImageView
        android:id="@+id/ivPreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:background="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvEditHint" />

    <!-- OCR 识别状态 -->
    <TextView
        android:id="@+id/tvOcrResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="等待识别..."
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:background="#CC000000"
        android:gravity="center"
        android:letterSpacing="0.15"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/tvEditHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- VIN 编辑框 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilVinEdit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:visibility="gone"
        android:hint="车架号 (可编辑)"
        app:endIconMode="clear_text"
        app:counterEnabled="true"
        app:counterMaxLength="17"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:layout_constraintBottom_toTopOf="@id/tvEditHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etVinEdit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:inputType="textVisiblePassword"
            android:maxLength="17"
            android:textSize="22sp"
            android:letterSpacing="0.15"
            android:textColor="@android:color/white"
            android:gravity="center" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 编辑提示 -->
    <TextView
        android:id="@+id/tvEditHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text=""
        android:textSize="13sp"
        android:textColor="#CCFFFFFF"
        android:background="#AA000000"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/tvSuggestions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 其他候选建议 -->
    <TextView
        android:id="@+id/tvSuggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:paddingHorizontal="16dp"
        android:text=""
        android:textSize="12sp"
        android:textColor="#99FFFFFF"
        android:background="#88000000"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 底部操作栏 -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#E0000000"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 拍照按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCapture"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text=""
            app:icon="@android:drawable/ic_menu_camera"
            app:iconSize="32dp"
            app:cornerRadius="36dp"
            android:backgroundTint="@android:color/white"
            style="@style/Widget.Material3.Button"
            android:layout_marginEnd="24dp" />

        <!-- 相册按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGallery"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text=""
            app:icon="@android:drawable/ic_menu_gallery"
            app:iconSize="24dp"
            app:cornerRadius="28dp"
            android:backgroundTint="#666666"
            style="@style/Widget.Material3.Button" />

        <!-- 切换候选按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSwitchVin"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="切换候选"
            android:textSize="12sp"
            android:visibility="gone"
            app:cornerRadius="24dp"
            android:backgroundTint="#444444"
            android:layout_marginEnd="8dp"
            style="@style/Widget.Material3.Button" />

        <!-- 重拍按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetake"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="重新拍照"
            android:textSize="14sp"
            app:cornerRadius="28dp"
            android:visibility="gone"
            android:layout_marginEnd="12dp"
            style="@style/Widget.Material3.Button" />

        <!-- 确认按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="确认使用"
            android:textSize="14sp"
            app:cornerRadius="28dp"
            android:visibility="gone"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

    <!-- 顶部工具栏 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent"
        app:title="拍照识别车架号"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationContentDescription="返回" />

</androidx.constraintlayout.widget.ConstraintLayout>
